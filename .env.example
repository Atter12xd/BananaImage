# Required: Vercel AI Gateway API key for image generation
AI_GATEWAY_API_KEY=

# Required: Secret for encrypting session cookies (min 32 characters)
SESSION_SECRET=

# Required: Supabase (rate limiting, usage, generation history)
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required: Vercel Blob storage for generated images
BLOB_READ_WRITE_TOKEN=

# Optional: Vercel OAuth (Sign in with Vercel)
# Without these, the app works in anonymous-only mode with rate limiting.
# Learn how: https://vercel.com/docs/sign-in-with-vercel
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=
